{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Overlay",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "message",
    "player",
    "opponent",
    "judgement"
  ],
  "properties": {
    "status": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message",
        "detail"
      ],
      "properties": {
        "message": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "player": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_name",
        "gender",
        "form",
        "mega_state",
        "speed_actual"
      ],
      "properties": {
        "display_name": {
          "type": "string"
        },
        "gender": {
          "type": "string"
        },
        "form": {
          "type": "string"
        },
        "mega_state": {
          "type": "string"
        },
        "speed_actual": {
          "type": "integer"
        }
      }
    },
    "opponent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_name",
        "gender",
        "form",
        "mega_state",
        "speed_candidates"
      ],
      "properties": {
        "display_name": {
          "type": "string"
        },
        "gender": {
          "type": "string"
        },
        "form": {
          "type": "string"
        },
        "mega_state": {
          "type": "string"
        },
        "speed_candidates": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "fastest",
            "neutral",
            "scarf_fastest",
            "scarf_neutral"
          ],
          "properties": {
            "fastest": {
              "type": "integer"
            },
            "neutral": {
              "type": "integer"
            },
            "scarf_fastest": {
              "type": "integer"
            },
            "scarf_neutral": {
              "type": "integer"
            }
          }
        }
      }
    },
    "judgement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vs_fastest",
        "vs_neutral",
        "vs_scarf_fastest",
        "vs_scarf_neutral"
      ],
      "properties": {
        "vs_fastest": {
          "type": "string"
        },
        "vs_neutral": {
          "type": "string"
        },
        "vs_scarf_fastest": {
          "type": "string"
        },
        "vs_scarf_neutral": {
          "type": "string"
        }
      }
    }
  }
}
